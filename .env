# LITTLE MIRACLES CLINIC - FRONTEND ENVIRONMENT VARIABLES
# ═════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values

# Backend API URL
# Development: http://localhost:5000
# Production: https://api.littlemiracles.clinic (or your backend domain)
VITE_API_URL=http://localhost:5000

# Optional: Google Analytics tracking ID (remove # and add your ID)
# VITE_GA_ID=G-XXXXXXXXXX
